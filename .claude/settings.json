{
  "enabledPlugins": {
    "ponytail@ponytail": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash D:\\PluginProject\\GlamSource\\.claude\\hooks\\check-bash.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash D:\\PluginProject\\GlamSource\\.claude\\hooks\\remind-push.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PostToolUse\",\"additionalContext\":\"REMINDER: Task abgeschlossen? Committen UND pushen.\"}}'",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"decision\":\"block\",\"reason\":\"Prüfe: Ist der Build grün? Wurde committed und gepusht? Falls nicht: weitermachen.\"}'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
